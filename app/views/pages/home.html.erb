<% content_for :title, "Random Walker | Research-ready web wandering" %>
<% content_for :head do %>
  <meta name="description" content="Random Walker is a compact discovery app for guided internet wandering, local trail saving, Markdown research reports, and JSON export.">
<% end %>

<div class="walker-shell">
  <header class="walker-topbar">
    <div>
      <p class="walker-kicker">Research Walker</p>
      <h1>Random Walker</h1>
    </div>
    <nav class="walker-topbar-links" aria-label="Primary">
      <%= link_to "Privacy", privacy_path %>
      <%= link_to "Terms", terms_path %>
      <%= mail_to @contact_email, "Contact" %>
    </nav>
  </header>

  <main class="walker-app-grid">
    <section class="walker-panel" aria-label="Walker controls">
      <form id="walker-start-form" class="walker-start" autocomplete="off">
        <label for="walker-start-url">Start URL</label>
        <div class="walker-start-fields">
          <input type="url" id="walker-start-url" name="start_url" placeholder="https://example.com" value="<%= @initial_url %>" required inputmode="url">
          <button type="submit">Set</button>
        </div>
      </form>

      <div class="walker-controls">
        <button type="button" id="walker-next">1 Walk</button>
        <button type="button" id="walker-stop" disabled>Stop</button>
        <button type="button" id="walker-auto" aria-pressed="false">Auto</button>
      </div>

      <div class="walker-trail-actions">
        <button type="button" id="walker-save-trail" disabled>Save trail</button>
        <button type="button" id="walker-export-trail" disabled>Export JSON</button>
        <button type="button" id="walker-import-trail">Import JSON</button>
        <input type="file" id="walker-import-trail-file" class="walker-file-input" accept="application/json,.json">
      </div>

      <section class="walker-research-panel" aria-labelledby="walker-research-title">
        <div class="walker-section-header">
          <p class="walker-card-kicker">Research Mode</p>
          <h2 id="walker-research-title">Trail Report</h2>
        </div>

        <form id="walker-research-form" class="walker-research-form" autocomplete="off">
          <label for="walker-research-topic">Research topic</label>
          <div class="walker-research-fields">
            <input type="text" id="walker-research-topic" name="research_topic" placeholder="例: Rails 個人開発の収益化">
            <button type="submit">Set</button>
          </div>
        </form>

        <p id="walker-research-summary" class="walker-research-summary">Set a topic to turn this walk into a report.</p>

        <div class="walker-research-status-actions" aria-label="Research decision">
          <button type="button" id="walker-research-keep" data-research-status="keep" disabled>Keep</button>
          <button type="button" id="walker-research-later" data-research-status="later" disabled>Later</button>
          <button type="button" id="walker-research-skip" data-research-status="skip" disabled>Skip</button>
        </div>

        <label class="walker-research-note-label" for="walker-research-note">Current page note</label>
        <textarea id="walker-research-note" class="walker-research-note" rows="4" placeholder="使える示唆、引用候補、次に調べることを書く" disabled></textarea>

        <div class="walker-research-export-actions">
          <button type="button" id="walker-export-markdown" disabled>Export Markdown</button>
          <button type="button" id="walker-copy-markdown" disabled>Copy Report</button>
        </div>
      </section>

      <section class="walker-mode-panel" aria-label="Walk modes">
        <button type="button" id="walker-ribbon-toggle" class="walker-ribbon-toggle" aria-pressed="false">
          <span class="walker-mode-name">同一サイト</span>
          <span id="walker-ribbon-summary" class="walker-mode-summary">同じサイト内と、ラベル付きリンクを優先します。</span>
        </button>
        <button type="button" id="walker-sweet-toggle" class="walker-sweet-toggle" aria-pressed="false">
          <span class="walker-mode-name">読みやすさ</span>
          <span id="walker-sweet-summary" class="walker-mode-summary">読みやすいリンクを優先します。</span>
        </button>
        <button type="button" id="walker-lucky-toggle" class="walker-lucky-toggle" aria-pressed="false">
          <span class="walker-mode-name">別ドメイン</span>
          <span id="walker-lucky-summary" class="walker-mode-summary">ときどき別ドメインへ飛びます。</span>
        </button>
      </section>

      <div class="walker-header-meta">
        <p id="walker-status" class="walker-status" role="status" aria-live="polite">Press "1 Walk" to begin wandering.</p>
        <p class="walker-current-url" aria-live="polite">
          <span class="walker-current-url-label">Viewing</span>
          <span id="walker-current-url" class="walker-current-url-value">No page loaded.</span>
        </p>
      </div>
    </section>

    <section class="walker-view-card">
      <div class="walker-section-header">
        <p class="walker-card-kicker">Safe Preview</p>
        <h2>Destination URL</h2>
      </div>

      <article class="walker-preview-card" id="walker-preview-card">
        <div class="walker-preview-heading">
          <p class="walker-preview-site" id="walker-preview-site">Destination URL</p>
          <h3 class="walker-preview-title" id="walker-preview-title"><%= @initial_url %></h3>
          <p class="walker-preview-description" id="walker-preview-description">Random Walker shows a safe embedded preview and keeps the original site one click away.</p>
        </div>

        <div class="walker-preview-frame-shell">
          <iframe
            id="walker-preview-frame"
            class="walker-preview-frame"
            title="Destination page"
            src="<%= walk_preview_path(url: @initial_url) %>"
            loading="lazy"
            referrerpolicy="strict-origin-when-cross-origin"
            sandbox="allow-forms allow-modals allow-popups allow-popups-to-escape-sandbox allow-scripts"></iframe>
        </div>

        <dl class="walker-preview-meta">
          <div><dt>Destination URL</dt><dd id="walker-preview-url"><%= @initial_url %></dd></div>
          <div><dt>Trail Label</dt><dd id="walker-preview-label">A selected link will show up here.</dd></div>
        </dl>

        <div class="walker-preview-actions">
          <a href="#" id="walker-preview-link" class="walker-cta-link is-disabled" target="_blank" rel="noopener noreferrer" aria-disabled="true">Open original page</a>
          <p class="walker-preview-note">Some sites block embedded display. Use the original page link when the frame is blank.</p>
        </div>
      </article>
    </section>

    <aside class="walker-history" aria-label="Visited URLs">
      <section class="walker-history-section">
        <div class="walker-section-header">
          <p class="walker-card-kicker">Trail Log</p>
          <h2>History</h2>
        </div>
        <p class="walker-history-note">訪問したURLをここに残します。</p>
        <ol id="walker-history-list"></ol>
      </section>

      <section class="walker-research-section" aria-labelledby="walker-research-brief-title">
        <div class="walker-section-header">
          <p class="walker-card-kicker">Research Brief</p>
          <h2 id="walker-research-brief-title">Report Items</h2>
        </div>
        <p id="walker-research-brief" class="walker-history-note">Set a topic and keep useful pages to build a Markdown report.</p>
        <ul id="walker-research-list" class="walker-research-list"></ul>
      </section>

      <section class="walker-saved-section" aria-labelledby="walker-saved-title">
        <div class="walker-section-header">
          <p class="walker-card-kicker">Saved Routes</p>
          <h2 id="walker-saved-title">Saved Trails</h2>
        </div>
        <p class="walker-history-note">Keep trails in this browser. ロード、再訪、JSON書き出しに使えます。</p>
        <ul id="walker-saved-list" class="walker-saved-list"></ul>
      </section>
    </aside>
  </main>

  <footer class="walker-site-footer">
    <p class="walker-footer-title">Random Walker</p>
    <nav class="walker-footer-links" aria-label="Footer">
      <%= link_to "Privacy", privacy_path %>
      <%= link_to "Terms", terms_path %>
      <%= mail_to @contact_email, "Contact" %>
    </nav>
  </footer>
</div>
