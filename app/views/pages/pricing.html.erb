<% content_for :title, "Pricing | Random Walker" %>
<% content_for :head do %>
  <meta name="description" content="Pricing ideas for monetizing Random Walker with supporter plans, creator packs, and a public-friendly launch model.">
<% end %>

<div class="walker-legal-shell">
  <header class="walker-legal-hero">
    <p class="walker-kicker">Pricing</p>
    <h1>Start with a support-first business model</h1>
    <p>
      このアプリは広告よりも、サポーター課金とテーマ追加販売の方が現実的です。
      最初は単純に売れて、運用負荷の低いプランに寄せます。
    </p>
    <div class="walker-link-row">
      <%= link_to "Back home", root_path, class: "walker-text-link" %>
      <a href="<%= @support_url %>" class="walker-text-link" target="_blank" rel="noopener">Support CTA</a>
    </div>
  </header>

  <section class="walker-pricing-section walker-pricing-page">
    <%= render "pricing_cards", plans: @plans, support_url: @support_url %>
  </section>
</div>
