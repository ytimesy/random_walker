#!/usr/bin/env bash
set -o errexit

# This app defaults to SQLite on Render. If a stray DATABASE_URL is present,
# Rails will try to boot the PostgreSQL adapter and fail unless pg is bundled.
if [ "${RANDOM_WALKER_USE_DATABASE_URL:-0}" != "1" ]; then
  unset DATABASE_URL
fi

bundle exec rails db:prepare
exec bundle exec rails server -b 0.0.0.0 -p "${PORT:-10000}"
